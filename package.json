{
  "name": "@stonyx/sockets",
  "keywords": [
    "stonyx-async",
    "stonyx-module"
  ],
  "version": "0.1.1-beta.25",
  "description": "WebSocket server and client module for the Stonyx framework",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "type": "module",
  "files": [
    "dist",
    "config",
    "LICENSE.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "default": "./dist/handler.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "pnpm build && pnpm build:test && NODE_ENV=test node --import tsx/esm --import ./test/setup.ts node_modules/qunit/bin/qunit.js 'test/**/*-test.ts'",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abofs/stonyx-sockets.git"
  },
  "author": "Stone Costa",
  "license": "Apache-2.0",
  "contributors": [
    "Stone Costa <stone.costa@synamicd.com>"
  ],
  "bugs": {
    "url": "https://github.com/abofs/stonyx-sockets/issues"
  },
  "homepage": "https://github.com/abofs/stonyx-sockets#readme",
  "dependencies": {
    "stonyx": "0.2.3-beta.56",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@stonyx/utils": "0.2.3-beta.23",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "qunit": "^2.24.1",
    "sinon": "^21.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
